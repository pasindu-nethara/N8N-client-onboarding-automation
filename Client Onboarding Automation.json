        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"subject\": {\n      \"type\": \"string\",\n      \"description\": \"A clear, exciting email subject line including the client's company name. Do not include the word 'Subject:'.\"\n    },\n    \"email_body_html\": {\n      \"type\": \"string\",\n      \"description\": \"The complete email body formatted in pure HTML with beautiful, professional inline CSS styling. It MUST follow this exact structure: 1. Introduction, 2. The Setup, 3. The Links, 4. Call to Action, 5. Sign-off. DESIGN INSTRUCTIONS: Use a modern corporate color palette (e.g., navy blue headers, dark slate text, and a soft background color for the unordered list area). Use clean sans-serif fonts (Arial, Helvetica, sans-serif). Style the Call to Action (Calendly link) as a prominent, colourful, rounded HTML button using inline CSS (e.g., background-color, padding, border-radius, text-decoration: none). Ensure the layout has good padding and spacing for a premium feel.\"\n    }\n  },\n  \"required\": [\n    \"subject\",\n    \"email_body_html\"\n  ],\n  \"additionalProperties\": false\n}"
